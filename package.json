{
  "name": "nudge-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:api": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs watch src/app/http-server.ts",
    "dev:worker": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs watch src/worker/worker-runner.ts",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:worker\"",
    "lint": "eslint src/ tests/ --ext .ts --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@fastify/cors": "^10.0.0",
    "@sentry/node": "^8.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "bullmq": "^5.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.6.0",
    "luxon": "^3.7.2",
    "openai": "^4.104.0",
    "pino": "^9.0.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-boundaries": "^5.0.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
